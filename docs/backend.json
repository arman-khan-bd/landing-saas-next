
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores additional profile information for users, linked to Firebase Authentication.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "fullName": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "createdAt"
      ]
    },
    "Store": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Store",
      "type": "object",
      "description": "Represents an individual e-commerce store.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "subdomain": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "subdomain",
        "ownerId",
        "createdAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product available for sale with detailed attributes.",
      "properties": {
        "id": {
          "type": "string"
        },
        "storeId": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "featuredImage": {
          "type": "string"
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "currentPrice": {
          "type": "number"
        },
        "prevPrice": {
          "type": "number"
        },
        "category": {
          "type": "string"
        },
        "subCategory": {
          "type": "string"
        },
        "brand": {
          "type": "string"
        },
        "totalInStock": {
          "type": "number"
        },
        "tax": {
          "type": "string"
        },
        "sku": {
          "type": "string"
        },
        "youtubeLink": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "storeId",
        "ownerId",
        "name",
        "slug",
        "currentPrice",
        "totalInStock",
        "createdAt"
      ]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "ownerId", "name", "slug", "createdAt"]
    },
    "SubCategory": {
      "title": "SubCategory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "ownerId": { "type": "string" },
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "ownerId", "categoryId", "name", "slug", "createdAt"]
    },
    "Brand": {
      "title": "Brand",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "ownerId", "name", "createdAt"]
    },
    "Tax": {
      "title": "Tax",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "percentage": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "ownerId", "name", "percentage", "createdAt"]
    },
    "Tag": {
      "title": "Tag",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "ownerId", "name", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "User-owned e-commerce stores."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products across all stores."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Store categories."
    },
    "/sub-categories/{subCategoryId}": {
      "schema": "SubCategory",
      "description": "Store sub-categories."
    },
    "/brands/{brandId}": {
      "schema": "Brand",
      "description": "Product brands."
    },
    "/taxes/{taxId}": {
      "schema": "Tax",
      "description": "Tax settings."
    },
    "/tags/{tagId}": {
      "schema": "Tag",
      "description": "Global product tags."
    }
  }
}
