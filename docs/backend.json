{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores additional profile information for users, linked to Firebase Authentication.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity, typically matching the Firebase Auth user ID."
        },
        "email": {
          "type": "string",
          "description": "The user's primary email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "createdAt"
      ]
    },
    "Store": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Store",
      "type": "object",
      "description": "Represents an individual e-commerce store (tenant).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Store entity."
        },
        "name": {
          "type": "string",
          "description": "The public-facing name of the store."
        },
        "subdomain": {
          "type": "string",
          "description": "The unique subdomain assigned to the store."
        },
        "ownerId": {
          "type": "string",
          "description": "Reference to the UserProfile that owns this store."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the store was created.",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "subdomain",
        "ownerId",
        "createdAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product available for sale.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "storeId": {
          "type": "string",
          "description": "Reference to the Store this product belongs to."
        },
        "ownerId": {
          "type": "string",
          "description": "Denormalized owner ID for authorization purposes."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "stock": {
          "type": "number",
          "description": "The current stock quantity."
        },
        "description": {
          "type": "string",
          "description": "The detailed description of the product."
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the product was created.",
          "format": "date-time"
        }
      },
      "required": [
        "storeId",
        "ownerId",
        "name",
        "price",
        "stock",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "User-owned e-commerce stores."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products across all stores, secured by ownerId."
    }
  }
}