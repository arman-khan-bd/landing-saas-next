
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores additional profile information for users, linked to Firebase Authentication.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "fullName": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "createdAt"
      ]
    },
    "Store": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Store",
      "type": "object",
      "description": "Represents an individual e-commerce store.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "subdomain": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "subdomain",
        "ownerId",
        "createdAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product available for sale with detailed attributes.",
      "properties": {
        "id": {
          "type": "string"
        },
        "storeId": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "featuredImage": {
          "type": "string"
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metaKeywords": {
          "type": "string"
        },
        "metaDescription": {
          "type": "string"
        },
        "currentPrice": {
          "type": "number"
        },
        "prevPrice": {
          "type": "number"
        },
        "category": {
          "type": "string"
        },
        "subCategory": {
          "type": "string"
        },
        "childCategory": {
          "type": "string"
        },
        "brand": {
          "type": "string"
        },
        "totalInStock": {
          "type": "number"
        },
        "tax": {
          "type": "string"
        },
        "sku": {
          "type": "string"
        },
        "youtubeLink": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "storeId",
        "ownerId",
        "name",
        "slug",
        "currentPrice",
        "totalInStock",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "User-owned e-commerce stores."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products across all stores."
    }
  }
}
