
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a multi-tenant e-commerce platform model (IHut.Shop) focusing on Tenant Isolation 
     * and Authorization Independence. Access control is primarily driven by denormalized ownership fields 
     * (`ownerId`) to ensure high performance and simplify security logic by avoiding cross-document lookups.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function isExistingOwner() {
      return isSignedIn() && resource != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner() && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if true;
      allow update: if isOwner(userId) || isAdmin();
    }

    match /adminRoles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Anyone can create an order (public checkout)
      allow create: if true;
      // Only the merchant or admin can view/manage order details
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /uncompleted_orders/{orderId} {
      // Allow guests to manage their own drafts
      allow create, get, update, delete: if true;
      // Only the merchant can list abandoned checkouts
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /fraud_blocks/{blockId} {
      // Public check during checkout (limited to query results)
      allow list: if (request.query.limit <= 5);

      // Merchant access
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isDataOwner();
      allow delete: if isSignedIn() && (isExistingOwner() || isAdmin());
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isExistingOwner();
      allow delete: if isAdmin();

      match /products/{productId} {
        allow get, list: if true;
        allow create: if isSignedIn() && isDataOwner();
        allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /subscription/{id} {
        allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // Platform Level / SaaS Admin Collections (Public Read / Admin Write)
    match /platformFeatures/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subscriptionPlans/{planId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /saasPaymentMethods/{methodId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /saas_transactions/{id} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /custom_domain_requests/{id} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Global Tenant Collections (Scoped by ownerId)
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /categories/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /sub-categories/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /brands/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /tags/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /taxes/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /pages/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /system_notifications/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
