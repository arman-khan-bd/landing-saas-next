rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a multi-tenant e-commerce platform model (NexusCart) focusing on Tenant Isolation 
     * and Authorization Independence. Access control is primarily driven by denormalized ownership fields 
     * (`ownerId`) to ensure high performance and simplify security logic by avoiding cross-document lookups.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if true;
      allow update: if isOwner(userId) || isAdmin();
    }

    match /adminRoles/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /uncompleted_orders/{orderId} {
      allow create: if true;
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /stores/{storeId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isExistingOwner(resource.data.ownerId);
      allow delete: if isAdmin();

      match /products/{productId} {
        allow get, list: if true;
        allow create: if isOwner(request.resource.data.ownerId);
        allow update: if isExistingOwner(resource.data.ownerId);
        allow delete: if isExistingOwner(resource.data.ownerId);
      }

      match /subscription {
        allow get: if isAdmin() || isExistingOwner(resource.data.ownerId);
        allow list: if isAdmin() || isOwner(storeId);
        allow create: if isAdmin() || (isOwner(request.resource.data.ownerId) && request.resource.data.storeId == storeId);
        allow update: if isAdmin() || (isExistingOwner(resource.data.ownerId));
        allow delete: if isAdmin();
      }
    }

    // Global Collections
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /categories/{id} { allow read, write: if true; }
    match /sub-categories/{id} { allow read, write: if true; }
    match /brands/{id} { allow read, write: if true; }
    match /tags/{id} { allow read, write: if true; }
    match /taxes/{id} { allow read, write: if true; }
    match /pages/{id} { allow read, write: if true; }

    match /subscriptionPlans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}