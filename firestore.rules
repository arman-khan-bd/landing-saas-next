
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a multi-tenant e-commerce platform model (IHut.Shop) focusing on Tenant Isolation 
     * and Authorization Independence.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid || 
        request.resource.data.userId == request.auth.uid
      );
    }

    function isExistingOwner() {
      return isSignedIn() && resource != null && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/stores/$(storeId)) &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner() && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if true;
      allow update: if isOwner(userId) || isAdmin();
    }

    match /adminRoles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /uncompleted_orders/{orderId} {
      allow create, get, update, delete: if true;
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /fraud_blocks/{blockId} {
      allow list: if (request.query.limit <= 5);
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isDataOwner();
      allow delete: if isSignedIn() && (isExistingOwner() || isAdmin());
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isExistingOwner();
      allow delete: if isAdmin();

      match /products/{productId} {
        allow get, list: if true;
        allow create: if isSignedIn() && isDataOwner();
        allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /subscription/{id} {
        allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /pages/{id} {
      allow read: if true;
      allow create: if isSignedIn() && (isDataOwner() || isStoreOwner(request.resource.data.storeId));
      allow update, delete: if isSignedIn() && (isExistingOwner() || isStoreOwner(resource.data.storeId) || isAdmin());
    }

    match /subscriptionPlans/{planId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /categories/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /sub-categories/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /brands/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /tags/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /taxes/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /saas_transactions/{id} {
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /custom_domain_requests/{id} {
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /system_notifications/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
