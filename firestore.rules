rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a multi-tenant e-commerce platform model (NexusCart) focusing on Tenant Isolation 
     * and Authorization Independence. Access control is primarily driven by denormalized ownership fields 
     * (`ownerId`) to ensure high performance and simplify security logic by avoiding cross-document lookups.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDataOwner() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function isExistingOwner() {
      return isSignedIn() && resource != null && resource.data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner() && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if true;
      allow update: if isOwner(userId) || isAdmin();
    }

    match /adminRoles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /uncompleted_orders/{orderId} {
      allow create: if true;
      allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /fraud_blocks/{blockId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isDataOwner();
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /stores/{storeId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || isExistingOwner();
      allow delete: if isAdmin();

      match /products/{productId} {
        allow get, list: if true;
        allow create: if isSignedIn() && isDataOwner();
        allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /subscription/{subId} {
        allow get, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && isDataOwner();
        allow update, delete: if isAdmin();
      }
    }

    // Global Collections (Scoped by ownerId)
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /categories/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /sub-categories/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /brands/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /tags/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /taxes/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /pages/{id} { 
      allow read: if true;
      allow create: if isSignedIn() && isDataOwner();
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /subscriptionPlans/{planId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}