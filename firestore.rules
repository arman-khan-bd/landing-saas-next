
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(docOwnerId) {
      return isSignedIn() && resource != null && docOwnerId == request.auth.uid;
    }

    function willBeOwner(proposedOwnerId) {
      return isSignedIn() && proposedOwnerId == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    match /categories/{id} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    match /sub-categories/{id} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    match /brands/{id} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    match /taxes/{id} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    match /tags/{id} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }
  }
}
