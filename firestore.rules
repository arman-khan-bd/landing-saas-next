rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user is the owner of the document by UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user owns the existing document. */
    function isExistingOwner(docOwnerId) {
      return isSignedIn() && resource != null && docOwnerId == request.auth.uid;
    }

    /** @description Checks if the user is assigning themselves as the owner of a new document. */
    function willBeOwner(proposedOwnerId) {
      return isSignedIn() && proposedOwnerId == request.auth.uid;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for stores. Publicly readable, owner-only writes.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Rules for products. Publicly readable, owner-only writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if willBeOwner(request.resource.data.ownerId);
      allow update, delete: if isExistingOwner(resource.data.ownerId);
    }
  }
}